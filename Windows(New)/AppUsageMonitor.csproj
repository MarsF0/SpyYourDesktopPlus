<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- 可执行名 / 任务管理器元数据（按需修改） -->
    <AssemblyName>SpyYourDesktopPlus</AssemblyName>
    <Company>澜轶小卖部＆Mars</Company>
    <Product>SpyYourDesktopPlus</Product>
    <AssemblyTitle>SpyYourDesktopPlus</AssemblyTitle>
    <Description>SpyYourDesktopPlus Windows Client</Description>
    <Version>0.0.2</Version>
    <FileVersion>0.0.2.0</FileVersion>

    <!-- 单文件、自包含、x64 -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
  </ItemGroup>
</Project>
